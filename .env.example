# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SUPABASE_URL: Found in Supabase Settings > API
SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_KEY: Found in Supabase Settings > API (anon public or service role)
SUPABASE_KEY="your-anon-key"
VITE_SUPABASE_KEY="your-anon-key"

# EMAIL_USER: The email address used for monitoring
EMAIL_USER="user@example.com"

# EMAIL_PASS: The app password or password for the IMAP server
EMAIL_PASS="password"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
